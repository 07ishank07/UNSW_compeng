# Copy to .env.local for local dev (.env.local is git-ignored). NEXT_PUBLIC_*
# values are public — they are inlined into the client bundle at build time.
# Full runbook: docs/deployment.md §5.1 / §5.6.
NEXT_PUBLIC_SANITY_PROJECT_ID="ex2of3t7"
NEXT_PUBLIC_SANITY_DATASET="production"
NEXT_PUBLIC_SANITY_API_VERSION="2026-06-01"

# true = offline mock content (src/data/mocks); false/unset = live Sanity.
# MUST be false for production builds — scripts/assert-deploy-env.mjs blocks
# `npm run deploy` otherwise (Next precedence trap: .env.local BEATS
# .env.production during `next build`).
NEXT_PUBLIC_USE_MOCKS=true

# Canonical https origin, no trailing slash — metadataBase, OG URLs, sitemap,
# robots. Production value lives in .github/workflows/deploy.yml env and
# wrangler.jsonc "vars".
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Server-only; currently UNUSED (reserved for a future draft-preview mode).
# Published reads need no token (useCdn + perspective: "published").
# SANITY_API_READ_TOKEN=""
